{
    "name": "tuxonice/pixel",
    "description": "PHP image server — MVC micro-framework on Symfony components",
    "type": "project",
    "require": {
        "php": "^8.3",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/config": "^7.0",
        "symfony/dotenv": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
